# Copy this file to ".env" and fill in ONE provider to enable live LLM calls.
# If you leave everything blank, the tool runs in deterministic "mock" mode.

# Choose: anthropic | openai | mock
LLM_PROVIDER=mock

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
